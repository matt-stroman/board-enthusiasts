{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tpl: dependencies up",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/dev.ps1",
        "up",
        "-DependenciesOnly"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "tpl: dependencies down",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/dev.ps1",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "tpl: trust dotnet dev certificate",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "dev-certs",
        "https",
        "--trust"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: build debug",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/backend/src/Board.ThirdPartyLibrary.Api/Board.ThirdPartyLibrary.Api.csproj",
        "-c",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "backend: build release",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/backend/src/Board.ThirdPartyLibrary.Api/Board.ThirdPartyLibrary.Api.csproj",
        "-c",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "backend: prepare debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "tpl: dependencies up",
        "backend: build debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "backend: prepare release",
      "dependsOrder": "sequence",
      "dependsOn": [
        "tpl: dependencies up",
        "backend: build release"
      ],
      "problemMatcher": []
    }
  ]
}
